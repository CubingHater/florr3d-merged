# Copy this file to `.env` and fill in your values.
# Restart the server after editing.

# --- Discord login (required for "Sign in with Discord") ---
# 1. Create an app at https://discord.com/developers/applications
# 2. OAuth2 → Add Redirect: https://YOUR-BACKEND-URL/auth/callback
#    (must match DISCORD_REDIRECT_URI exactly — no trailing slash)
# 3. Copy Client ID + Client Secret below
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Backend callback URL (Cloudflare tunnel or ngrok pointing at localhost:8081)
DISCORD_REDIRECT_URI=https://your-tunnel.trycloudflare.com/auth/callback

# Keeps login sessions valid across server restarts (generate any random string)
SESSION_SECRET=change-me-to-a-long-random-string

# --- Vercel frontend + local backend ---
# Your Vercel URL (no trailing slash). Enables CORS + cross-site cookies.
FRONTEND_URL=https://your-app.vercel.app

# --- Optional ---
# PORT=8081
# DEV_AUTH=1
# DISCORD_BOT_TOKEN=
# DISCORD_ULTRA_CHANNEL_ID=

# Set these in Vercel (Project → Settings → Environment Variables), not here:
# VITE_API_URL=https://your-tunnel.trycloudflare.com
# VITE_WS_URL=wss://your-tunnel.trycloudflare.com/ws
